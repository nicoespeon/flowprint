{
	"plugins": ["node-workspace"],
	"packages": {
		"packages/core": {
			"release-type": "node",
			"component": "flowprint-core",
			"skip-github-release": true
		},
		"packages/cli": {
			"release-type": "node",
			"component": "flowprint",
			"changelog-path": "CHANGELOG.md"
		},
		"packages/vscode": {
			"release-type": "node",
			"component": "flowprint-vscode",
			"changelog-path": "CHANGELOG.md"
		}
	}
}
