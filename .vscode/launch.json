{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/packages/vscode",
				"${workspaceFolder}/playground"
			],
			"outFiles": ["${workspaceFolder}/packages/vscode/dist/**/*.js"],
			"preLaunchTask": "build:vscode"
		}
	]
}
