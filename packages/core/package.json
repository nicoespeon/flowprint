{
	"name": "@flowprint/core",
	"version": "1.0.0",
	"description": "Data flow tracing engine for TypeScript",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"typescript",
		"data-flow",
		"trace",
		"static-analysis",
		"ts-morph"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nicoespeon/flowprint.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/nicoespeon/flowprint",
	"bugs": "https://github.com/nicoespeon/flowprint/issues",
	"engines": {
		"node": ">=20"
	},
	"license": "MIT",
	"dependencies": {
		"ts-morph": "27.0.2"
	}
}
