{
	"name": "flowprint",
	"version": "0.0.0",
	"description": "Trace data flow across TypeScript codebases",
	"type": "module",
	"bin": {
		"flowprint": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node esbuild.config.js",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"typescript",
		"data-flow",
		"trace",
		"static-analysis",
		"cli",
		"call-hierarchy"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/nicoespeon/flowprint.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/nicoespeon/flowprint",
	"bugs": "https://github.com/nicoespeon/flowprint/issues",
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"license": "MIT",
	"dependencies": {
		"ts-morph": "27.0.2"
	},
	"devDependencies": {
		"@flowprint/core": "workspace:*"
	}
}
