{
	"name": "flowprint-vscode",
	"displayName": "flowprint",
	"description": "Trace data flow across TypeScript codebases",
	"version": "0.1.0",
	"publisher": "nicoespeon",
	"icon": "icon.png",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"typescript",
		"data-flow",
		"trace",
		"static-analysis",
		"call-hierarchy"
	],
	"galleryBanner": {
		"color": "#171A22",
		"theme": "dark"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nicoespeon/flowprint.git",
		"directory": "packages/vscode"
	},
	"homepage": "https://github.com/nicoespeon/flowprint",
	"bugs": "https://github.com/nicoespeon/flowprint/issues",
	"activationEvents": [
		"onLanguage:typescript",
		"onLanguage:typescriptreact"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "flowprint.traceUpstream",
				"title": "Flowprint: Trace Data Flow (Upstream)"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "flowprint.traceUpstream",
					"when": "editorLangId == typescript || editorLangId == typescriptreact",
					"group": "0_navigation@5"
				}
			]
		},
		"views": {
			"explorer": [
				{
					"id": "flowprint.traceView",
					"name": "Data Flow",
					"when": "flowprint.hasTrace"
				}
			]
		}
	},
	"scripts": {
		"build": "node esbuild.config.mjs",
		"build:watch": "node esbuild.config.mjs --watch",
		"package": "node esbuild.config.mjs --production && vsce package --no-dependencies",
		"deploy:vscode": "node esbuild.config.mjs --production && vsce publish --no-dependencies",
		"deploy:ovsx": "node esbuild.config.mjs --production && ovsx publish --no-dependencies"
	},
	"devDependencies": {
		"@flowprint/core": "workspace:*",
		"@types/vscode": "1.110.0"
	},
	"license": "MIT"
}
